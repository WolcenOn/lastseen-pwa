{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "go mod download && go build -trimpath -ldflags='-s -w' -o ./lastseen ./cmd/server"
  },
  "deploy": {
    "startCommand": "./lastseen",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
